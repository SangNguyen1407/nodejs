<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <script type="text/javascript">
      function printDate(){
        youbi    = new Array ("日", "月", "火", "水", "木", "金", "土");
        now_date = new Date();
        date     = now_date.getDate();
        day      = youbi[now_date.getDay()];
        month    = now_date.getMonth() + 1 ;
        year     = now_date.getFullYear();

        document.write(year + "年" + month + "月" + date + "日" + "(" + day +")");
      }
    </script>
 
  <div class="menu">
    <div class="menu_tab">
      <a class="active" href="#home">Home</a>
      <a href="#news">News</a>
      <a href="#contact">Contact</a>
      <a href="#about">About</a>
    </div>
    <div class="menu_version">
      <a1>Ver 1.0</a1>
    </div>
  </div>

  <div class="mainpage">
    <div class="title">
      <h1><%= title %></h1>
      <p>
        Welcome to <%= title %> 
        <script type="text/javascript">
            printDate()
        </script>
      </p>
    </div>

    <div id="imageContainer" class = "displayImage">
        <img id="displayedImage" src="" alt="Local image">
    </div>

    <div class="table1">
      <table id="table_persons" border="1px solid black">
        <thead>
          <tr>
              <th>Person ID</th>
              <th>LastName</th>
              <th>FirstName</th>
              <th>Address</th>
              <th>City</th>
              <th></th>
          </tr>
        </thead>

        <tbody>
          <tr>
            <% data.forEach(function(row) { %>
                <tr>
                    <% for (let key in row) { %>
                        <td><%= row[key] %></td>
                    <% } %>
                    <td> <button onclick="displayImage()">写真</button> </td>
                    <script>
                        function displayImage() {
                            const imagePath = './images/IMG_5825.jpg';
                            document.getElementById('displayedImage').src = imagePath;
                            document.getElementById('imageContainer').style.display = 'block';
                            }
                    </script>
                </tr>
            <% }); %>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="table2">
      <table id="table_persons" border="1px solid black">
        <thead>
          <tr>
              <th>Person ID</th>
              <th>LastName</th>
              <th>FirstName</th>
              <th>Address</th>
              <th>City</th>
          </tr>
        </thead>

        <tbody>
          <tr>
            <% data.forEach(function(row) { %>
                <tr>
                    <% for (let key in row) { %>
                        <td><%= row[key] %></td>
                    <% } %>
                </tr>
            <% }); %>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  </body>
</html>
